* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: 17px;
  line-height: 1.75;
  min-height: 100vh;
}

/* Noise texture overlay */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
  opacity: 0.5;
}

.wrapper {
  position: relative;
  z-index: 1;
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ── MASTHEAD ── */
header {
  border-bottom: 4px double var(--rule);
  padding: 32px 0 20px;
  text-align: center;
  animation: fadeDown 0.6s ease both;
}

.masthead-eyebrow {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 14px;
}

.masthead-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 7vw, 72px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--ink);
}

.masthead-title span {
  color: var(--accent);
  font-style: italic;
}

.masthead-sub {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.12em;
  color: var(--muted);
  margin-top: 16px;
  text-transform: uppercase;
}

/* ── TICKER ── */
.ticker-wrap {
  background: var(--ink);
  color: var(--paper);
  overflow: hidden;
  padding: 8px 0;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 12px;
  letter-spacing: 0.06em;
  animation: fadeDown 0.6s 0.1s ease both;
}

.ticker-inner {
  display: inline-block;
  white-space: nowrap;
  animation: ticker 28s linear infinite;
}

.ticker-inner span { margin: 0 48px; }
.ticker-inner .sep { color: var(--accent); }

@keyframes ticker {
  from { transform: translateX(100vw); }
  to   { transform: translateX(-100%); }
}

/* ── HERO HEADLINE ── */
.hero {
  padding: 48px 0 32px;
  border-bottom: 1px solid var(--rule);
  animation: fadeUp 0.7s 0.2s ease both;
}

.kicker {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 500;
  margin-bottom: 12px;
}

h1.headline {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}

.deck {
  font-size: 18px;
  color: var(--muted);
  font-style: italic;
  max-width: 640px;
  line-height: 1.6;
}

.byline-row {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-top: 20px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.byline-row .dot { color: var(--accent); }

/* ── STATUS BADGE ── */
.status-strip {
  background: var(--accent);
  color: #fff;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 10px 0;
  text-align: center;
  margin: 0 -24px;
  animation: fadeUp 0.7s 0.3s ease both;
}

/* ── BODY CONTENT ── */
.content-grid {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 48px;
  padding: 48px 0;
  animation: fadeUp 0.7s 0.35s ease both;
}

@media (max-width: 680px) {
  .content-grid { grid-template-columns: 1fr; gap: 32px; }
}

/* Main column */
.main-col section { margin-bottom: 40px; }

.section-rule {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
}

.section-rule h2 {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}

.section-rule::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--muted);
  opacity: 0.35;
}

.main-col p {
  margin-bottom: 20px;
  color: var(--ink);
}

.pullquote {
  border-left: 3px solid var(--accent);
  margin: 32px 0;
  padding: 16px 24px;
  background: var(--highlight);
}

.pullquote p {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 20px;
  line-height: 1.5;
  color: var(--ink);
  margin: 0;
}

.pullquote cite {
  display: block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 10px;
  font-style: normal;
}

/* Sidebar */
.sidebar {
  padding-top: 4px;
}

.sidebar-card {
  border: 1px solid rgba(44,34,24,0.2);
  padding: 24px;
  margin-bottom: 28px;
  background: var(--highlight);
}

.sidebar-card h3 {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(44,34,24,0.15);
}

.sidebar-card ul {
  list-style: none;
  padding: 0;
}

.sidebar-card ul li {
  font-size: 14px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(44,34,24,0.08);
  line-height: 1.5;
  color: var(--ink);
}

.sidebar-card ul li:last-child { border-bottom: none; }

.sidebar-card ul li strong {
  display: block;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 2px;
}

.timeline-dot {
  display: inline-block;
  width: 7px; height: 7px;
  background: var(--accent);
  border-radius: 50%;
  margin-right: 8px;
  vertical-align: middle;
  flex-shrink: 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid rgba(44,34,24,0.08);
  font-size: 14px;
  line-height: 1.5;
}

.timeline-item:last-child { border-bottom: none; }

.timeline-date {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  white-space: nowrap;
  margin-top: 2px;
}

/* ── FOOTER ── */
footer {
  border-top: 4px double var(--rule);
  padding: 28px 0;
  text-align: center;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 0.1em;
  animation: fadeUp 0.7s 0.5s ease both;
}

footer a { color: var(--muted); }

/* ── ANIMATIONS ── */
@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
